<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.o_murphy.ebalistyka</id>

  <name>eBalistyka</name>
  <summary>Ballistic trajectory calculator</summary>
  <description>
    <p>
      eBalistyka is a professional ballistic calculator for shooters.
      Supports trajectory calculation, wind drift, multiple ammo profiles,
      and custom reticle overlays.
    </p>
  </description>

  <url type="homepage">https://github.com/o-murphy/ebalistyka-app</url>
